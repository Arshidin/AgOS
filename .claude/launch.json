{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Frontend (Vite)",
      "runtimeExecutable": "/usr/local/bin/node",
      "runtimeArgs": ["node_modules/vite/bin/vite.js"],
      "port": 5173
    },
    {
      "name": "AI Gateway (FastAPI)",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "uvicorn", "ai_gateway.main:app", "--loop", "asyncio", "--http", "h11", "--port", "8000"],
      "port": 8000
    },
    {
      "name": "calculate-ration (Edge Function)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["supabase", "functions", "serve", "calculate-ration"],
      "port": 54321
    }
  ]
}
